# Email delivery for submitted forms (Resend — https://resend.com)
# On each successful form submission, the filled PDF is emailed to MAIL_TO.

# Required — create at https://resend.com/api-keys
RESEND_API_KEY=

# Optional — sender. Must be a domain verified in Resend (e.g. "WLTH <forms@wlth.com>").
# If unset, the shared Resend onboarding sender is used, which in test mode can
# only deliver to the Resend account owner's own email address.
MAIL_FROM=WLTH Client Hub <onboarding@resend.dev>

# Optional — recipient(s), comma-separated. Defaults to a.fernandes@wlth.com.
MAIL_TO=a.fernandes@wlth.com
